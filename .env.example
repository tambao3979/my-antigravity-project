# ============================================================
#  Cấu hình hệ thống FireWatch AI
#  Sao chép file này thành .env và điền thông tin của bạn
# ============================================================

# ── Telegram ──────────────────────────────────────────────
# Token bot Telegram (lấy từ @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Chat ID (lấy từ @userinfobot)
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Model YOLO ────────────────────────────────────────────
MODEL_PATH=path/to/your/best.pt

# Tên nhãn lớp fire/smoke trong model
FIRE_CLASS_NAME=fire
SMOKE_CLASS_NAME=smoke

# Ngưỡng độ tin cậy (0.0 - 1.0)
CONFIDENCE_THRESHOLD=0.25
FIRE_CONFIDENCE_THRESHOLD=0.05
SMOKE_CONFIDENCE_THRESHOLD=0.05

# Stronger YOLO inference for small fire and overlapping objects
YOLO_MIN_CONF=0.01
YOLO_IMGSZ=960
YOLO_IOU=0.85
YOLO_MAX_DET=300
YOLO_AGNOSTIC_NMS=false
YOLO_AUGMENT=false

# Extra tiled pass for tiny hazards. Higher values improve recall but cost FPS.
TILED_DETECTION_ENABLED=true
TILED_DETECTION_CLASSES=fire,smoke
TILED_DETECTION_TILE_SIZE=512
TILED_DETECTION_OVERLAP=128
TILED_DETECTION_BATCH_SIZE=4
TILED_DETECTION_MERGE_IOU=0.85
OVERLAY_DEDUP_ENABLED=true
OVERLAY_DEDUP_IOU=0.45
OVERLAY_DEDUP_CONTAINMENT=0.75
DISPLAY_TARGET_FPS=60
LIVE_CAPTURE_TARGET_FPS=60
INFERENCE_BATCH_SIZE=1
BOX_SMOOTHING_ENABLED=true
BOX_SMOOTHING_ALPHA=0.65
BOX_PREDICT_MAX_FRAMES=60
BOX_MATCH_IOU=0.20
BOX_MATCH_CENTER_RATIO=0.45
FIRE_MISSING_GRACE_SECONDS=1.0

# ── Quy tắc cảnh báo ─────────────────────────────────────
FIRE_CONFIRM_SECONDS=5
ALERT_COOLDOWN_SECONDS=60
ALERT_SEND_RETRIES=2
ALERT_RETRY_BACKOFF_SECONDS=0.5

# Event database, snapshots, exports
EVENT_DIR=events
EVENT_DB_PATH=events/events.db
EVENT_SNAPSHOT_DIR=events/snapshots
EXPORT_DIR=exports

# Optional MQTT alert publishing. Install paho-mqtt to enable real publishing.
MQTT_ENABLED=false
MQTT_HOST=127.0.0.1
MQTT_PORT=1883
MQTT_TOPIC=camera_ai/alerts
MQTT_CLIENT_ID=camera-ai-edge

# Lightweight hardware resource monitor
RESOURCE_MONITOR_ENABLED=true
RESOURCE_MONITOR_INTERVAL_SECONDS=2.0
RESOURCE_MONITOR_GPU_INDEX=0

# ── Camera ────────────────────────────────────────────────
# Health checks and system alerts
CAMERA_HEALTH_CHECK_INTERVAL_SECONDS=1.0
CAMERA_DISCONNECT_TIMEOUT_SECONDS=30.0
CAMERA_RECONNECT_BASE_DELAY_SECONDS=1.0
CAMERA_RECONNECT_MAX_DELAY_SECONDS=30.0
GPU_ALERT_USAGE_THRESHOLD_PERCENT=90.0
GPU_ALERT_CONSECUTIVE_SAMPLES=3
INFERENCE_LATENCY_ALERT_THRESHOLD_MS=250.0
INFERENCE_LATENCY_ALERT_CONSECUTIVE_SAMPLES=3
SYSTEM_ALERT_REPEAT_COOLDOWN_SECONDS=60.0

# Local RBAC accounts
AUTH_ADMIN_USERNAME=admin
AUTH_ADMIN_PASSWORD=change_this_admin_password
AUTH_USER_USERNAME=user
AUTH_USER_PASSWORD=change_this_user_password

CAMERA_INDEX=0
FRAME_WIDTH=1280
FRAME_HEIGHT=720
